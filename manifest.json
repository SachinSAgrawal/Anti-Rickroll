{
  "manifest_version": 3,
  "name": "Anti Rickroll",
  "description": "Displays a warning when you navigate to a potential YouTube rickroll with an optional password to continue.",
  "version": "1.0",
  "content_scripts": [
    {
      "js": [
        "background/content.js"
      ],
      "matches": [
        "https://*.youtube.com/*",
        "https://bit.ly/*"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "warn/warn.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "permissions": [
    "tabs",
    "storage"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}